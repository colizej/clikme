# Переменные окружения — .env.example
#
# Скопировать в .env и заполнить реальными значениями:
#   cp .env.example .env
#
# НИКОГДА не коммитить .env в git!
# Этот файл (.env.example) — безопасно хранить в git.

# ==========================================
# ОБЯЗАТЕЛЬНЫЕ
# ==========================================

# Генерировать: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=replace-with-50-random-chars

# False — в production. True — только локально
DEBUG=False

# Домены через запятую
ALLOWED_HOSTS=clikme.ru,www.clikme.ru

# Нестандартный URL для Django Admin (скрыть от ботов)
ADMIN_URL=manage-clikme-2026

# ==========================================
# AI / GitHub Models API
# ==========================================

# github → GitHub Models (бесплатно с Copilot подпиской)
# openai → OpenAI API
AI_PROVIDER=github

# Получить: github.com → Settings → Developer Settings →
# Personal access tokens → Fine-grained → право models:read
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Если AI_PROVIDER=openai — раскомментировать:
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx

# ==========================================
# TELEGRAM
# ==========================================

# @BotFather → /newbot → скопировать API Token
TELEGRAM_BOT_TOKEN=1234567890:ABCdefghijklmnopqrstuvwxyz

# Числовой ID канала или @username
TELEGRAM_CHANNEL_ID=-1001234567890

# ==========================================
# ПЛАТЕЖИ — MOLLIE (Западные, Фаза 2)
# ==========================================

# test_xxx — для development/staging (без реальных списаний)
# live_xxx — для production
MOLLIE_API_KEY=test_xxxxxxxxxxxxxxxxxxxx

# URL куда Mollie POST-ит webhook при изменении статуса платежа
MOLLIE_WEBHOOK_URL=https://clikme.ru/payments/webhook/

# ==========================================
# ПЛАТЕЖИ — РОССИЙСКИЕ (Фаза 2, позже)
# ==========================================

# Провайдер будет определён позже
# RUSSIAN_PAYMENT_API_KEY=

# ==========================================
# TRIP.COM AFFILIATE
# ==========================================

TRIP_ALLIANCE_ID=6229959
TRIP_SID=192412375

# ==========================================
# EMAIL (заполнить после выбора SMTP-провайдера)
# ==========================================

# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=noreply@clikme.ru
# EMAIL_HOST_PASSWORD=your-smtp-password
# DEFAULT_FROM_EMAIL=КликМи <noreply@clikme.ru>

# Для локального теста без SMTP (письма в консоль):
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# ==========================================
# БАЗА ДАННЫХ (только при переходе с SQLite)
# ==========================================

# По умолчанию используется SQLite — менять только для PostgreSQL:
# DATABASE_URL=postgres://user:password@localhost:5432/clikme_db
